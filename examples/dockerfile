FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    iproute2 \
    ca-certificates \
    curl \
    git \
    dnsutils \
    python3 \
    python3-full \
    python3-pip \
    python3-venv \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Dockerfile is the setup contract: copy source and install deps at build time.
COPY . /workspace
RUN if [ -f requirements.txt ]; then python3 -m pip install --break-system-packages -r requirements.txt; fi
RUN python3 -m pip install --break-system-packages pytest

# Default command for SparkVM when run_cmd override is not provided.
CMD ["python3", "-m", "pytest", "-q"]
